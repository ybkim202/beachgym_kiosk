# ============================================================
# 일산비치짐 키오스크 — 환경변수 예시
# 이 파일을 복사해서 .env.local 로 만들고 값을 채우세요.
#   cp .env.example .env.local   (PowerShell: Copy-Item .env.example .env.local)
# ============================================================

# ---- Supabase (필수) ----
# Supabase 프로젝트 > Settings > API 에서 확인
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # service_role 키 (절대 외부 노출 금지)

# ---- 관리자 웹 (필수) ----
ADMIN_PASSWORD=원하는_관리자_비밀번호
ADMIN_SECRET=세션쿠키_서명용_랜덤문자열   # 아무 긴 랜덤 문자열

# ---- 카카오 알림톡 (선택 — 준비되면 입력. 없으면 콘솔 로그로 대체) ----
# NOTIFY_PROVIDER=solapi          # solapi | sms | console (미지정 시 키 있으면 solapi)
# SOLAPI_API_KEY=
# SOLAPI_API_SECRET=
# SOLAPI_SENDER=01012345678       # 사전 등록된 발신번호
# KAKAO_PF_ID=                    # 카카오 비즈채널 발신프로필 키(pfId)
# KAKAO_TEMPLATE_ID=              # 승인된 알림톡 템플릿 ID

# ---- 외부 링크 (선택 — STEP4/완료 화면 QR 및 알림톡에 사용) ----
# NEXT_PUBLIC_HOMEPAGE_URL=https://ilsanbeachgym.com
# NEXT_PUBLIC_RESERVATION_URL=https://ilsanbeachgym.com/reserve
# NEXT_PUBLIC_SURVEY_URL=https://ilsanbeachgym.com/survey
# NEXT_PUBLIC_GUIDE_URL=https://ilsanbeachgym.com/guide

# ---- 운영 옵션 (선택) ----
# MAX_STAY_MINUTES=240            # 체크인 후 자동 마감까지 분 (현재 이용객 산정)
